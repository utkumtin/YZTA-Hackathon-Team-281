# -------------------------
# Telegram
# -------------------------
# @BotFather'dan alınan bot token
TELEGRAM_BOT_TOKEN=

# Patron rolü için Telegram kullanıcı ID'si (sayı — string değil!)
# Öğrenmek için: @userinfobot veya @RawDataBot'a mesaj atın
OWNER_TELEGRAM_ID=

# Webhook imzası doğrulaması için rastgele string
# Üretmek için: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Polling modu (ngrok yoksa true — webhook yerine polling kullanır)
USE_POLLING=false

# Demo müşteri rolü için test hesabının chat_id'si
# S2 proaktif mesaj testleri için gerekli
DEMO_CUSTOMER_TG_ID=

# -------------------------
# LLM (Gemini)
# -------------------------
# Google AI Studio'dan alınan API key
GEMINI_API_KEY=

# LLM provider
LLM_PROVIDER=gemini

# Model adı
LLM_MODEL=gemini-2.5-flash

# -------------------------
# Database
# -------------------------
# Docker Compose içinde db servisi için:
DATABASE_URL=postgresql+asyncpg://kobi:kobi@db:5432/kobi_db

# Yerel geliştirme için (Docker dışı):
# DATABASE_URL=postgresql+asyncpg://kobi:kobi@localhost:5432/kobi_db

# -------------------------
# Observability
# -------------------------
# Log seviyesi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Logfire token (opsiyonel — boşsa Logfire devre dışı)
LOGFIRE_TOKEN=

# -------------------------
# Demo & Environment
# -------------------------
# Ortam: demo | dev | prod
ENV=demo

# /demo/* endpoint'lerini aç (production'da false olmalı)
DEMO_MODE_ENABLED=true
